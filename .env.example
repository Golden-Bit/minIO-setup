# ============================================================================
# MinIO setup - environment template
# Copia questo file in .env e personalizza i valori.
# I segreti NON devono essere versionati.
# ============================================================================

# ---------------------------------------------------------------------------
# Immagini Docker
# ---------------------------------------------------------------------------
# Tag pinned: evita l'uso di :latest in ambienti seri.
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MC_IMAGE=minio/mc:RELEASE.2025-07-21T05-28-08Z

# ---------------------------------------------------------------------------
# Credenziali root MinIO (obbligatorie)
# ---------------------------------------------------------------------------
# L'utente root ha accesso amministrativo completo.
# NON usare queste credenziali dall'applicazione business.
MINIO_ROOT_USER=CHANGE_ME_ROOT_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_SUPER_STRONG

# ---------------------------------------------------------------------------
# Data / region / timezone
# ---------------------------------------------------------------------------
# Directory dati interna al container MinIO.
MINIO_DATA_DIR=/data

# Regione logica S3. Non è obbligatoria in tutti i casi ma è utile per coerenza.
MINIO_REGION_NAME=eu-south-1

# Timezone del container.
TZ=Europe/Rome

# ---------------------------------------------------------------------------
# Binding porte lato host
# ---------------------------------------------------------------------------
# Default sicuro: bind solo su loopback.
# Per esporre direttamente le porte (sconsigliato in pubblico), imposta 0.0.0.0.
MINIO_API_BIND_IP=127.0.0.1
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_BIND_IP=127.0.0.1
MINIO_CONSOLE_HOST_PORT=9001

# Host usato dagli script locali per healthcheck.
# Di norma lascialo 127.0.0.1 anche se usi Nginx davanti.
MINIO_HEALTHCHECK_HOST=127.0.0.1
MINIO_HEALTHCHECK_SCHEME=http

# ---------------------------------------------------------------------------
# URL pubblici / reverse proxy (opzionali ma fortemente consigliati se pubblichi)
# ---------------------------------------------------------------------------
# URL pubblico dell'API S3 esposta da reverse proxy o LB.
# Esempio: https://minio.example.com
MINIO_SERVER_URL=

# URL pubblico della Console.
# Esempio: https://console.minio.example.com
MINIO_BROWSER_REDIRECT_URL=

# Se true, MinIO redirige i browser verso la Console.
MINIO_BROWSER_REDIRECT=true

# Console embedded attiva/disattiva.
# In generale lascia on.
MINIO_BROWSER=on

# Animazione login Console: on/off.
MINIO_BROWSER_LOGIN_ANIMATION=off

# Durata sessione browser, ad esempio 12h, 24h, 7d.
MINIO_BROWSER_SESSION_DURATION=12h

# ---------------------------------------------------------------------------
# Virtual-host style buckets (opzionale avanzato)
# ---------------------------------------------------------------------------
# Imposta il dominio base bucket solo se sai di aver predisposto DNS/TLS wildcard.
# Esempio: s3.example.com
# Con questo approccio un bucket può diventare: my-bucket.s3.example.com
MINIO_DOMAIN=

# ---------------------------------------------------------------------------
# Prometheus / metrics
# ---------------------------------------------------------------------------
# public = endpoint metrics accessibile senza auth
# jwt    = richiede token JWT
MINIO_PROMETHEUS_AUTH_TYPE=public

# ---------------------------------------------------------------------------
# Bootstrap iniziale (opzionale)
# ---------------------------------------------------------------------------
# Bucket iniziali separati da virgola.
# Esempio: app-uploads,app-private,backups
MINIO_DEFAULT_BUCKETS=

# Se true, abilita il versioning per i bucket creati in bootstrap.
MINIO_ENABLE_VERSIONING=true

# Utente applicativo opzionale (raccomandato se l'app deve usare MinIO).
MINIO_DEFAULT_USER=
MINIO_DEFAULT_USER_PASSWORD=

# Policy built-in da assegnare all'utente creato in bootstrap.
# Valori tipici: readwrite, readonly, consoleAdmin, diagnostics
MINIO_DEFAULT_USER_POLICY=readwrite

# ---------------------------------------------------------------------------
# Backup / restore
# ---------------------------------------------------------------------------
BACKUP_DIR=./backups
DATA_DIR=./data
